# =============================
# Misskey connection
# =============================
MISSKEY_BASE_URL=https://your-misskey.example.com
# Optional: if omitted, ws/wss is derived automatically from MISSKEY_BASE_URL
# MISSKEY_WS_URL=wss://your-misskey.example.com
MISSKEY_TOKEN=put_your_misskey_token_here

# Optional: restrict normal posts / auto posts to a specific Misskey channel.
# Replies automatically reuse the incoming note's channel when present.
MISSKEY_CHANNEL_ID=

# Optional overrides. Normally the bot auto-detects both via /api/i.
BOT_USERNAME=
BOT_USER_ID=

# =============================
# LLM backend
# =============================
# Docker Desktop on macOS/Windows can usually reach host Ollama like this:
LLM_API_URL=http://host.docker.internal:11434/v1/chat/completions

# If you run Ollama in the same compose stack, use one of these instead:
# LLM_API_URL=http://ollama:11434/v1/chat/completions
# LLM_API_URL=http://ollama:11434/api/chat

LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b
MAX_TOKENS=300
TEMPERATURE=0.8
REQUEST_TIMEOUT_MS=120000

# =============================
# Bot behavior
# =============================
MAX_MEMORY=20
MAX_OUTPUT_CHARS=1200
SYSTEM_PROMPT=You are a helpful Misskey bot. Reply naturally in Korean unless the user clearly uses another language.

# Reply visibility
# inherit = use the incoming note's visibility
# fixed   = always use REPLY_DEFAULT_VISIBILITY below
REPLY_VISIBILITY_MODE=inherit
REPLY_DEFAULT_VISIBILITY=home
INHERIT_LOCAL_ONLY=true
FORCE_LOCAL_ONLY=false

# Access control
# off                = anyone can use the bot
# local_only         = only local users can use the bot
# followers_only     = only users who follow the bot
# following_only     = only users the bot follows
# followers_or_local = local users or followers
# following_or_local = local users or users the bot follows
# mutual_or_local    = local users or either side follows
ACCESS_MODE=following_or_local
ALLOWED_INSTANCE=your-misskey.example.com
RELATION_DEBUG=false

# Automatic follow-back
AUTO_FOLLOW_BACK=false
AUTO_FOLLOW_LOCAL_ONLY=false

# Optional autonomous posting
ENABLE_AUTO_POST=false
AUTO_POST_PROMPT=Write a short, natural social post suitable for Misskey.
AUTO_POST_MIN_MINUTES=30
AUTO_POST_MAX_MINUTES=240

LOG_LEVEL=info
