# -----------------------------
# Misskey connection
# -----------------------------
MISSKEY_BASE_URL=https://misskey.example.com
# Optional: if omitted, ws/wss URL is derived from MISSKEY_BASE_URL.
MISSKEY_WS_URL=wss://misskey.example.com
MISSKEY_TOKEN=REPLACE_WITH_YOUR_MISSKEY_TOKEN

# Optional: restrict normal posts / auto posts to a specific Misskey channel.
# Replies will automatically reuse the incoming note's channel when present.
MISSKEY_CHANNEL_ID=

# Optional overrides. Usually the bot can auto-detect both values via /api/i.
BOT_USERNAME=
BOT_USER_ID=


# -----------------------------
# LLM backend
# -----------------------------
# Docker Desktop on macOS -> use host-side Ollama or another OpenAI-compatible backend.
LLM_API_URL=http://host.docker.internal:11434/v1/chat/completions
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b
MAX_MEMORY=20
MAX_TOKENS=300
TEMPERATURE=0.8
REQUEST_TIMEOUT_MS=120000
SYSTEM_PROMPT=You are a friendly Misskey bot. Reply naturally in Korean unless the user clearly uses another language.

# -----------------------------
# Access control / reply behavior
# -----------------------------
ACCESS_MODE=following_or_local
# Set this to your Misskey instance host if you want explicit local-instance matching.
ALLOWED_INSTANCE=misskey.example.com
AUTO_FOLLOW_BACK=false
AUTO_FOLLOW_LOCAL_ONLY=false
REPLY_VISIBILITY_MODE=inherit
REPLY_DEFAULT_VISIBILITY=home
INHERIT_LOCAL_ONLY=true
FORCE_LOCAL_ONLY=false
MAX_OUTPUT_CHARS=3000
LOG_LEVEL=info

# -----------------------------
# Auto post (optional)
# -----------------------------
ENABLE_AUTO_POST=false
AUTO_POST_PROMPT=Write a short, natural social post suitable for Misskey. Avoid hashtags unless relevant.
AUTO_POST_MIN_MINUTES=30
AUTO_POST_MAX_MINUTES=240

# -----------------------------
# ComfyUI image generation
# -----------------------------
# Keep this disabled until you place a real API workflow JSON in ./workflows/comfyui_api_workflow.json.
ENABLE_IMAGE_GENERATION=false
COMFYUI_BASE_URL=http://host.docker.internal:8000
COMFYUI_WORKFLOW_FILE=/app/workflows/comfyui_api_workflow.json
COMFYUI_DIFFUSION_MODEL=anima-preview3-base.safetensors
COMFYUI_TEXT_ENCODER=qwen_3_06b_base.safetensors
COMFYUI_VAE=qwen_image_vae.safetensors
COMFYUI_WIDTH=1024
COMFYUI_HEIGHT=1024
COMFYUI_BATCH_SIZE=1
COMFYUI_STEPS=50
COMFYUI_CFG=4.5
COMFYUI_SAMPLER=dpmpp_2m_sde_gpu
COMFYUI_SCHEDULER=normal
COMFYUI_POSITIVE_PREFIX=masterpiece, best quality, score_7
COMFYUI_NEGATIVE=worst quality, low quality, score_1, score_2, score_3, blurry, bad anatomy, bad hands, extra fingers, missing fingers, extra arms, extra legs, cropped hands
COMFYUI_DENOISE=1.0
IMAGE_COMMAND_PREFIXES=/img,/image,/그림
IMAGE_TIMEOUT_SEC=180
IMAGE_POLL_INTERVAL_MS=1500
IMAGE_REQUIRE_PREFIX=true

# -----------------------------
# NSFW moderation (bot side)
# -----------------------------
ENABLE_NSFW_FILTER=true
NSFW_API_BASE_URL=http://nsfw-api:8000
NSFW_REQUEST_TIMEOUT_MS=120000
NSFW_BLOCK_REVIEW=true
NSFW_BLOCK_SCORE=0.8
NSFW_QUARANTINE_DIR=/app/quarantine
IMAGE_BLOCKED_REPLY_TEXT=생성된 이미지가 안전 기준에 맞지 않아 첨부하지 않았어요.

# -----------------------------
# NSFW service thresholds
# -----------------------------
NSFW_SAFE_THRESHOLD=0.2
NSFW_THRESHOLD=0.8
NSFW_MAX_UPLOAD_MB=20
