# =========================================================
# Misskey LLM Bot - sample environment file
# =========================================================

# -----------------------------
# Misskey connection
# -----------------------------
MISSKEY_BASE_URL=https://misskey.example.com
MISSKEY_TOKEN=put_your_misskey_token_here

ACCESS_MODE=following_or_local
ALLOWED_INSTANCE=misskey.example.com
AUTO_FOLLOW_BACK=true
AUTO_FOLLOW_LOCAL_ONLY=false

# Optional: if omitted, ws/wss URL is derived automatically from MISSKEY_BASE_URL
# MISSKEY_WS_URL=wss://misskey.example.com

# Optional: restrict normal posts / auto posts to a specific Misskey channel.
# Replies automatically reuse the incoming note's channel when present.
MISSKEY_CHANNEL_ID=

# Optional overrides. Usually the bot can auto-detect both values via /api/i.
BOT_USERNAME=
BOT_USER_ID=

# -----------------------------
# LLM backend
# -----------------------------
# Docker Desktop on macOS/Windows -> use host Ollama
LLM_API_URL=http://host.docker.internal:11434/v1/chat/completions
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b
MAX_TOKENS=800
TEMPERATURE=0.7
REQUEST_TIMEOUT_MS=240000

# -----------------------------
# Bot behavior
# -----------------------------
MAX_MEMORY=80
MAX_OUTPUT_CHARS=1200
SYSTEM_PROMPT=You are a friendly Misskey bot. Reply naturally and clearly. Prefer Korean unless the user clearly uses another language.

# Reply visibility
# inherit = use the same visibility as the incoming note (recommended)
# fixed   = always use REPLY_DEFAULT_VISIBILITY below
REPLY_VISIBILITY_MODE=inherit
REPLY_DEFAULT_VISIBILITY=home
INHERIT_LOCAL_ONLY=true
FORCE_LOCAL_ONLY=false

# Auto posting is disabled by default.
ENABLE_AUTO_POST=false
AUTO_POST_PROMPT=Write a short, natural social post suitable for Misskey.
AUTO_POST_MIN_MINUTES=30
AUTO_POST_MAX_MINUTES=240

# -----------------------------
# Image generation via external ComfyUI Desktop
# -----------------------------
ENABLE_IMAGE_GENERATION=true

# Docker container -> host ComfyUI Desktop
COMFYUI_BASE_URL=http://host.docker.internal:8000
COMFYUI_WORKFLOW_FILE=/app/workflows/anima_preview3_qwen_txt2img_api.json

# Anima Preview3 model stack
COMFYUI_DIFFUSION_MODEL=anima-preview3-base.safetensors
COMFYUI_TEXT_ENCODER=qwen_3_06b_base.safetensors
COMFYUI_VAE=qwen_image_vae.safetensors

# Generation settings
COMFYUI_WIDTH=1024
COMFYUI_HEIGHT=1024
COMFYUI_BATCH_SIZE=1
COMFYUI_STEPS=50
COMFYUI_CFG=4.5
COMFYUI_SAMPLER=dpmpp_2m_sde_gpu
COMFYUI_SCHEDULER=normal
COMFYUI_POSITIVE_PREFIX=masterpiece, best quality, score_7
COMFYUI_NEGATIVE=worst quality, low quality, score_1, score_2, score_3, blurry, bad anatomy, bad hands, extra fingers, missing fingers, extra arms, extra legs, cropped hands
COMFYUI_DENOISE=1.0

# Command parsing
IMAGE_COMMAND_PREFIXES=/img,/image,/그림
IMAGE_TIMEOUT_SEC=600
IMAGE_POLL_INTERVAL_MS=2000
IMAGE_REQUIRE_PREFIX=true

# -----------------------------
# Logging
# -----------------------------
LOG_LEVEL=info
